rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.superAdminReferrer == true ||
        request.auth.token.superAdmin == true
      );
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /admin/{uid} {
      allow read: if isOwner(uid) || isSuperAdmin();
      allow write: if false;
    }

    match /admin/{uid}/ticketSales/{saleId} {
      allow read: if isOwner(uid) || isSuperAdmin();
      allow write: if false;
    }

    // Alias lookup supports ref/email login UX from the public login page.
    match /adminLoginAliases/{aliasKey} {
      allow read: if true;
      allow write: if false;
    }

    match /referralClicks/{docId} {
      allow create: if true;
      allow read: if isSuperAdmin();
      allow update, delete: if false;
    }

    match /raffle_entries/{entryId} {
      allow read: if isSuperAdmin() || (isSignedIn() && resource.data.referrerUid == request.auth.uid);
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}